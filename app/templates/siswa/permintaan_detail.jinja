{% if not is_htmx %}
    {% extends "siswa/layout.jinja" %}
    {% block title %}Detail Permintaan{% endblock %}
{% else %}
    <title>Detail Permintaan</title>
{% endif %}

{% from 'macros.jinja' import render_notif %}

{% block content %}

{{ render_notif(error, success, info) }}

<h4 class="mb-3">Detail Permintaan</h4>

<div class="row">
    <div class="col">
        <div class="card rounded-0 mb-3" style="max-width: 720px;">
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th style="width: 200px;">Tanggal</th>
                        <td>{{ req.date.strftime('%d/%m/%Y') if req.date else '-' }}</td>
                    </tr>
                    <tr>
                        <th>Kategori</th>
                        <td>{{ req.category.name if req.category else '-' }}</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>
                            {% if req.status == 'pending' %}
                            <span class="badge bg-warning text-dark">Pending</span>
                            {% elif req.status == 'accepted' %}
                            <span class="badge bg-success">Diterima</span>
                            {% elif req.status == 'rejected' %}
                            <span class="badge bg-danger">Ditolak</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th>Catatan Siswa</th>
                        <td>{{ req.student_note or '-' }}</td>
                    </tr>
                    <tr>
                        <th>Catatan Guru</th>
                        <td>{{ req.teacher_note or '-' }}</td>
                    </tr>
                    {% if req.reviewer %}
                    <tr>
                        <th>Ditinjau oleh</th>
                        <td>{{ req.reviewer.name or req.reviewer.username }}</td>
                    </tr>
                    {% endif %}
                    {% if req.reviewed_at %}
                    <tr>
                        <th>Ditinjau pada</th>
                        <td>{{ req.reviewed_at.strftime('%d/%m/%Y %H:%M') }}</td>
                    </tr>
                    {% endif %}
                </table>
                <a class="btn btn-secondary"
                   hx-get="{{ url_for('siswa.beranda') }}">
                   Kembali
                </a>
            </div>
        </div>
    </div>
</div>

{% endblock %}
