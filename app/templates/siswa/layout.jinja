<!doctype html>
<html lang="id">
<head>
    <title>{% block title %}{% endblock %}</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" type="text/css" href="{{ url_for('static', filename='css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" type="text/css" href="{{ url_for('static', filename='css/datatables.min.css') }}">
    <link rel="stylesheet" type="text/css" href="{{ url_for('static', filename='css/style.css') }}">
    <script type="text/javascript" src="{{ url_for('static', filename='js/jquery.min.js') }}"></script>
    <script type="text/javascript" src="{{ url_for('static', filename='js/bootstrap.bundle.min.js') }}"></script>
    <script type="text/javascript" src="{{ url_for('static', filename='js/datatables.min.js') }}"></script>
    <script type="text/javascript" src="{{ url_for('static', filename='js/htmx.min.js') }}"></script>
</head>
<body hx-boost="true" hx-push-url="true">
<div class="app-layout">
    <aside class="app-sidebar" id="appSidebar" hx-target="#hx_content" hx-swap="innerHTML">
        <div class="app-brand">
            <a href="{{ url_for('siswa.beranda') }}"
               hx-get="{{ url_for('siswa.beranda') }}">
                <i class="bi bi-laptop"></i> {{ app_name }}
            </a>
        </div>
        <nav class="app-sidebar-nav">
            <a class="app-nav-link" data-nav-key="beranda"
               href="{{ url_for('siswa.beranda') }}"
               hx-get="{{ url_for('siswa.beranda') }}">
                <i class="bi bi-house-door"></i><span>Beranda</span>
            </a>
        </nav>
    </aside>
    <div class="app-sidebar-backdrop" id="sidebarBackdrop"></div>
    <div class="app-main">
        <header class="app-topbar">
            <button class="btn btn-sm btn-link text-decoration-none text-secondary d-lg-none"
                    type="button" aria-label="Buka menu" id="sidebarToggle">
                <i class="bi bi-list fs-4"></i>
            </button>
            <div class="app-topbar-user ms-auto">
                <span class="text-truncate">{{ student_name }}</span>
                <span class="badge text-bg-secondary">Siswa</span>
                <a class="btn btn-sm btn-outline-secondary"
                   href="{{ url_for('siswa.logout') }}" hx-boost="false">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </a>
            </div>
        </header>
        <main class="p-4 position-relative">
            <div class="hx-spinner-overlay" id="hx-spinner">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
            <div id="hx_content">
                {% block content %}{% endblock %}
            </div>
        </main>
    </div>
</div>
<script type="text/javascript" src="{{ url_for('static', filename='js/app.js') }}"></script>
</body>
</html>
