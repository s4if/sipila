{% if not is_htmx %}
    {% extends "admin/layout.jinja" %}
    {% block title %}{{ 'Edit Rombel' if class_group else 'Tambah Rombel' }}{% endblock %}
{% else %}
    <title>{{ 'Edit Rombel' if class_group else 'Tambah Rombel' }}</title>
{% endif %}

{% from 'macros.jinja' import render_notif %}

{% block content %}

{{ render_notif(error, success, info) }}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ url_for('admin.rombel') }}"
            hx-get="{{ url_for('admin.rombel') }}"
            hx-target="#hx_content"
            hx-swap="innerHTML">Data Rombel</a></li>
        <li class="breadcrumb-item active">{{ 'Edit Rombel' if class_group else 'Tambah Rombel' }}</li>
    </ol>
</nav>
<h1 class="h2">{{ 'Edit Rombel' if class_group else 'Tambah Rombel' }}</h1>

<div class="row">
    <div class="col">
        <form method="POST"
              action="{{ url_for('admin.rombel_edit', id=class_group.id) if class_group else url_for('admin.rombel_tambah') }}"
              hx-post="{{ url_for('admin.rombel_edit', id=class_group.id) if class_group else url_for('admin.rombel_tambah') }}"
              hx-target="#hx_content"
              hx-swap="innerHTML">
            {{ form.hidden_tag() }}
            <div class="mb-3">
                {{ form.grade_level.label(class='form-label') }}
                {{ form.grade_level(class='form-select' + (' is-invalid' if form.grade_level.errors else ''), required=True) }}
                {% if form.grade_level.errors %}
                <div class="invalid-feedback">
                    {% for error in form.grade_level.errors %}{{ error }}{% endfor %}
                </div>
                {% endif %}
            </div>
            <div class="mb-3">
                {{ form.major.label(class='form-label') }}
                {{ form.major(class='form-select' + (' is-invalid' if form.major.errors else '')) }}
                {% if form.major.errors %}
                <div class="invalid-feedback">
                    {% for error in form.major.errors %}{{ error }}{% endfor %}
                </div>
                {% endif %}
            </div>
            <div class="mb-3">
                {{ form.name.label(class='form-label') }}
                {{ form.name(class='form-control' + (' is-invalid' if form.name.errors else ''), required=True, placeholder='Contoh: 1, 2, 3') }}
                {% if form.name.errors %}
                <div class="invalid-feedback">
                    {% for error in form.name.errors %}{{ error }}{% endfor %}
                </div>
                {% endif %}
            </div>
            <div class="mb-3">
                {{ form.homeroom_teacher_id.label(class='form-label') }}
                {{ form.homeroom_teacher_id(class='form-select' + (' is-invalid' if form.homeroom_teacher_id.errors else '')) }}
                {% if form.homeroom_teacher_id.errors %}
                <div class="invalid-feedback">
                    {% for error in form.homeroom_teacher_id.errors %}{{ error }}{% endfor %}
                </div>
                {% endif %}
            </div>
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">
                    {{ 'Simpan Perubahan' if class_group else 'Tambah Rombel' }}
                </button>
                <a class="btn btn-secondary ms-2"
                   href="{{ url_for('admin.rombel') }}"
                   hx-get="{{ url_for('admin.rombel') }}"
                   hx-target="#hx_content"
                   hx-swap="innerHTML">Batal</a>
            </div>
        </form>
    </div>
</div>

{% endblock %}
