{% if not is_htmx %}
    {% extends "admin/layout.jinja" %}
    {% block title %}Data Rombel{% endblock %}
{% else %}
    <title>Data Rombel</title>
{% endif %}

{% from 'macros.jinja' import render_notif %}

{% block content %}

{{ render_notif(error, success, info) }}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item active">Data Rombel</li>
    </ol>
</nav>
<h1 class="h2">Data Rombongan Belajar</h1>

<div class="row mb-3">
    <div class="col">
        <a class="btn btn-primary"
           href="{{ url_for('admin.rombel_tambah') }}"
           hx-get="{{ url_for('admin.rombel_tambah') }}"
           hx-target="#hx_content"
           hx-swap="innerHTML">
            <i class="bi bi-plus-lg"></i> Tambah Rombel
        </a>
    </div>
</div>

<div class="row">
    <div class="col">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>No</th>
                    <th>Nama Rombel</th>
                    <th>Tingkat</th>
                    <th>Jurusan</th>
                    <th>Wali Kelas</th>
                    <th>Jumlah Siswa</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                {% for cg in class_groups %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td>{{ cg.display_name }}</td>
                    <td>{{ cg.grade_level }}</td>
                    <td>{{ cg.major or '-' }}</td>
                    <td>{{ cg.homeroom_teacher.name or '[nama belum di set]' if cg.homeroom_teacher else '-' }}</td>
                    <td>{{ cg.active_student_count }}</td>
                    <td>
                        <a class="btn btn-sm btn-warning"
                           hx-get="{{ url_for('admin.rombel_edit', id=cg.id) }}"
                           hx-target="#hx_content"
                           hx-swap="innerHTML">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <button type="button" class="btn btn-sm btn-danger"
                                onclick="hapus_rombel({{ cg.id }}, '{{ cg.display_name }}')">
                            <i class="bi bi-trash"></i> Hapus
                        </button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="text-center">Belum ada data rombel</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalHapus" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Konfirmasi Hapus</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>
            <div class="modal-body">
                Apakah Anda yakin ingin menghapus rombel <strong id="modalHapusNama"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <form id="modalHapusForm" hx-post="{{ url_for('admin.rombel_hapus') }}" style="display:inline"
                      onsubmit="tutup_modal()">
                    <input type="hidden" name="id" id="modalHapusId" value=""/>
                    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}"/>
                    <button type="submit" class="btn btn-danger">Hapus</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
var hapus_rombel = (id, nama) => {
    document.getElementById('modalHapusId').value = id;
    document.getElementById('modalHapusNama').textContent = nama;
    var modal = new bootstrap.Modal(document.getElementById('modalHapus'));
    modal.show();
};
var tutup_modal = () => {
    bootstrap.Modal.getInstance(document.getElementById('modalHapus')).hide();
};
</script>

{% endblock %}
