{% if not is_htmx %}
    {% extends "admin/layout.jinja" %}
    {% block title %}Data Siswa{% endblock %}
{% else %}
    <title>Data Siswa</title>
{% endif %}

{% from 'macros.jinja' import render_notif %}

{% block content %}

{{ render_notif(error, success, info) }}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h4 class="mb-0">Data Siswa</h4>
    <div class="d-flex gap-2">
        <a class="btn btn-primary"
           href="{{ url_for('admin.siswa_tambah') }}"
           hx-get="{{ url_for('admin.siswa_tambah') }}"
           hx-target="#hx_content"
           hx-swap="innerHTML">
            <i class="bi bi-plus-lg"></i> Tambah Siswa
        </a>
        {% if is_superadmin %}
        <button type="button" class="btn btn-success" onclick="open_import_modal()">
            <i class="bi bi-upload"></i> Import Excel
        </button>
        <a class="btn btn-outline-success" hx-boost="false"
           href="{{ url_for('admin.siswa_template') }}">
            <i class="bi bi-download"></i> Download Template
        </a>
        {% endif %}
    </div>
</div>

<div class="table-responsive">
        <table id="siswaTable" class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>No</th>
                    <th>NIS</th>
                    <th>Nama</th>
                    <th>Rombel</th>
                    <th>Catatan Admin</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
</div>

<div class="modal fade" id="modalHapus" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Konfirmasi Hapus</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>
            <div class="modal-body">
                Apakah Anda yakin ingin menghapus siswa <strong id="modalHapusNama"></strong>?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <form id="modalHapusForm" hx-post="{{ url_for('admin.siswa_hapus') }}" style="display:inline"
                      onsubmit="tutup_modal()">
                    <input type="hidden" name="id" id="modalHapusId" value=""/>
                    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}"/>
                    <button type="submit" class="btn btn-danger">Hapus</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalImport" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Import Siswa dari Excel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>
            <form id="modalImportForm" hx-post="{{ url_for('admin.siswa_import') }}"
                  hx-target="#hx_content" hx-swap="innerHTML"
                  enctype="multipart/form-data"
                  onsubmit="tutup_import_modal()">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="importFile" class="form-label">Pilih file .xlsx</label>
                        <input type="file" class="form-control" id="importFile" name="file"
                               accept=".xlsx" required/>
                    </div>
                    <div class="form-text">
                        Download template terlebih dahulu, isi data siswa, lalu unggah kembali.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <input type="hidden" name="csrf_token" value="{{ csrf_token() }}"/>
                    <button type="submit" class="btn btn-success">Import</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
var hapus_siswa = (id, nama) => {
    document.getElementById('modalHapusId').value = id;
    document.getElementById('modalHapusNama').textContent = nama;
    var modal = new bootstrap.Modal(document.getElementById('modalHapus'));
    modal.show();
};
var tutup_modal = () => {
    bootstrap.Modal.getInstance(document.getElementById('modalHapus')).hide();
};
var open_import_modal = () => {
    var modal = new bootstrap.Modal(document.getElementById('modalImport'));
    modal.show();
};
var tutup_import_modal = () => {
    bootstrap.Modal.getInstance(document.getElementById('modalImport')).hide();
};
var edit_siswa = (id) => {
    var raw_url = "{{url_for('admin.siswa_edit', id=0)}}"
    var url = raw_url.slice(0, -1) + String(id)
    htmx.ajax("GET", url, {target:'#hx_content', swap:'innerHTML'})
};
(function() {
    if ($.fn.DataTable.isDataTable('#siswaTable')) {
        $('#siswaTable').DataTable().destroy();
        $('#siswaTable').empty();
    }
    $('#siswaTable').DataTable({
        ajax: {
            url: '{{ url_for("admin.siswa_data") }}',
            dataSrc: 'data'
        },
        columns: [
            { data: 'no' },
            { data: 'student_id' },
            { data: 'name' },
            { data: 'class_group' },
            { data: 'admin_note' },
            { data: 'actions', orderable: false, searchable: false }
        ],
        language: {
            search: 'Cari:',
            lengthMenu: 'Tampilkan _MENU_ data',
            info: 'Menampilkan _START_ - _END_ dari _TOTAL_ data',
            infoEmpty: 'Belum ada data siswa',
            emptyTable: 'Belum ada data siswa',
            zeroRecords: 'Tidak ditemukan data yang cocok',
            paginate: { previous: 'Sebelumnya', next: 'Selanjutnya' }
        }
    });
})();
</script>

{% endblock %}
