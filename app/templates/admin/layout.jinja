<!doctype html>
<html>
<head>
    <title>{% block title %}{% endblock %}</title>
    <meta charset="UTF-8">
    <meta name="description" content="The small framework with powerful features">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" type="text/css" href="{{ url_for('static', filename='css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" type="text/css" href="{{ url_for('static', filename='css/datatables.min.css') }}">
    <style type="text/css">
        .fix-padding {
            padding-top: 10px;
        }
        #sidebar {
            border-right: 1px solid rgba(0, 0, 0, 1);
        }
        @media (min-width: 768px) {
            #sidebar {
                height: 100vh;
                position: sticky;
                top: 0;
                overflow-y: auto;
            }
        }
        .navbar {
            box-shadow: inset 0 -1px 0 rgba(0, 0, 0, .1);
        }
        @media (min-width: 767.98px) {
            .navbar {
                top: 0;
                position: sticky;
                z-index: 999;
            }
        }
        .hx-spinner-overlay {
          position: absolute;
          inset: 0;
          display: none;
          align-items: center;
          justify-content: center;
          background: rgba(255, 255, 255, 0.7);
          z-index: 100;
        }
        .hx-spinner-overlay.show {
          display: flex;
        }
    </style>
    <script type="text/javascript" src="{{ url_for('static', filename='js/jquery.min.js') }}"></script>
    <script type="text/javascript" src="{{ url_for('static', filename='js/bootstrap.bundle.min.js') }}"></script>
    <script type="text/javascript" src="{{ url_for('static', filename='js/datatables.min.js') }}"></script>
    <script type="text/javascript" src="{{ url_for('static', filename='js/htmx.min.js') }}"></script>
</head>
<body hx-boost="true" hx-push-url="true">

<nav class="navbar navbar-dark bg-dark p-3">
        <div class="d-flex col-12 col-md-3 col-lg-2 mb-2 mb-lg-0 flex-wrap flex-md-nowrap justify-content-between">
            <a class="navbar-brand" href="#">
                {{ app_name }}
            </a>
            <button id="sb-toggler" class="navbar-toggler d-md-none collapsed mb-3" type="button" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
        <div class="col-12 col-md-5 col-lg-8 d-flex align-items-center justify-content-md-end mt-3 mt-md-0">
            <div class="dropdown">
                <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                  ADMIN: {{ username }}
                </button>
                <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                  <li><a class="dropdown-item" href="{{ url_for('admin.ganti_password') }}"
                  hx-target="#hx_content"
                  hx-swap="innerHTML"
                  >Ganti Password</a></li>
                  <li><a hx-boost="false" class="dropdown-item" href="{{ url_for('auth.logout') }}">Sign out</a></li>
                </ul>
              </div>
        </div>
    </nav>
    <div class="container-fluid">
        <div class="row">
            <div id="sidebar" class="col-xl-2 col-lg-2 col-md-3 d-none d-md-block">
                <nav class="nav flex-column nav-underline"
                    hx-target="#hx_content"
                    hx-swap="innerHTML"
                >
                    <a class="nav-link" id="nav-beranda"
                       hx-get="{{ url_for('admin.beranda') }}">
                    Beranda
                    </a>
                    <a class="nav-link" id="nav-siswa"
                       hx-get="{{ url_for('admin.siswa') }}">
                    Siswa
                    </a>

                    <a class="nav-link" id="nav-rombel"
                       hx-get="{{ url_for('admin.rombel') }}">
                    Rombel
                    </a>

                    <a class="nav-link" id="nav-kategori"
                       hx-get="{{ url_for('admin.kategori') }}">
                    Kategori
                    </a>

                    {% if is_superadmin %}
                    <a class="nav-link" id="nav-guru"
                       hx-get="{{ url_for('admin.guru') }}">
                    Guru
                    </a>
                    {% endif %}
                </nav>
            </div>
            <main class="col-xl-10 col-lg-10 col-md-9 col-12 fix-padding">
              <div class="row position-relative" hx-target="#hx_content" hx-swap="innerHTML">
                <div class="col" id="hx_content">
                {% block content %} {% endblock %}
                </div>
                <div class="hx-spinner-overlay" id="hx-spinner">
                  <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                  </div>
                </div>
              </div>
            </main>
        </div>
    </div>
    <script type="text/javascript">
    const hxSpinner = document.getElementById('hx-spinner');
    document.addEventListener('htmx:beforeRequest', function(event) {
      hxSpinner.classList.add('show');
    });
    document.addEventListener('htmx:afterRequest', function(event) {
      hxSpinner.classList.remove('show');
    });
    document.addEventListener('htmx:afterSwap', function(event) {
      hxSpinner.classList.remove('show');
    });
    const sbToggler = document.getElementById('sb-toggler');
    const sidebar = document.getElementById('sidebar');
    sbToggler.addEventListener('click', () => {
        sidebar.classList.toggle('d-none');
        sidebar.classList.toggle('d-md-block');
    });
    </script>
</body>
</html>
