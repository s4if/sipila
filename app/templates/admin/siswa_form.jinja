{% if not is_htmx %}
    {% extends "admin/layout.jinja" %}
    {% block title %}{{ 'Edit Siswa' if student else 'Tambah Siswa' }}{% endblock %}
{% else %}
    <title>{{ 'Edit Siswa' if student else 'Tambah Siswa' }}</title>
{% endif %}

{% from 'macros.jinja' import render_notif %}

{% block content %}

{{ render_notif(error, success, info) }}

<h4 class="mb-3">{{ 'Edit Siswa' if student else 'Tambah Siswa' }}</h4>

<div class="row">
    <div class="col">
        <form method="POST"
              action="{{ url_for('admin.siswa_edit', id=student.id) if student else url_for('admin.siswa_tambah') }}"
              hx-post="{{ url_for('admin.siswa_edit', id=student.id) if student else url_for('admin.siswa_tambah') }}"
              hx-target="#hx_content"
              hx-swap="innerHTML">
            {{ form.hidden_tag() }}
            <div class="mb-3">
                {{ form.student_id.label(class='form-label') }}
                {{ form.student_id(class='form-control' + (' is-invalid' if form.student_id.errors else ''), required=True) }}
                {% if form.student_id.errors %}
                <div class="invalid-feedback">
                    {% for error in form.student_id.errors %}{{ error }}{% endfor %}
                </div>
                {% endif %}
            </div>
            <div class="mb-3">
                {{ form.name.label(class='form-label') }}
                {{ form.name(class='form-control' + (' is-invalid' if form.name.errors else ''), required=True) }}
                {% if form.name.errors %}
                <div class="invalid-feedback">
                    {% for error in form.name.errors %}{{ error }}{% endfor %}
                </div>
                {% endif %}
            </div>
            <div class="mb-3">
                {{ form.password.label(class='form-label') }}
                {% if student %}
                <div class="form-text">Kosongkan jika tidak ingin mengubah password</div>
                {% endif %}
                {{ form.password(class='form-control' + (' is-invalid' if form.password.errors else ''), **{'required': True} if not student else {'placeholder': 'Password baru'}) }}
                {% if form.password.errors %}
                <div class="invalid-feedback">
                    {% for error in form.password.errors %}{{ error }}{% endfor %}
                </div>
                {% endif %}
            </div>
            <div class="mb-3">
                {{ form.class_group_id.label(class='form-label') }}
                {{ form.class_group_id(class='form-select' + (' is-invalid' if form.class_group_id.errors else ''), required=True) }}
                {% if form.class_group_id.errors %}
                <div class="invalid-feedback">
                    {% for error in form.class_group_id.errors %}{{ error }}{% endfor %}
                </div>
                {% endif %}
            </div>
            <div class="mb-3">
                {{ form.admin_note.label(class='form-label') }}
                {{ form.admin_note(class='form-control' + (' is-invalid' if form.admin_note.errors else '')) }}
                {% if form.admin_note.errors %}
                <div class="invalid-feedback">
                    {% for error in form.admin_note.errors %}{{ error }}{% endfor %}
                </div>
                {% endif %}
            </div>
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">
                    {{ 'Simpan Perubahan' if student else 'Tambah Siswa' }}
                </button>
                <a class="btn btn-secondary ms-2"
                   href="{{ url_for('admin.siswa') }}"
                   hx-get="{{ url_for('admin.siswa') }}"
                   hx-target="#hx_content"
                   hx-swap="innerHTML">Batal</a>
            </div>
        </form>
    </div>
</div>

{% endblock %}
