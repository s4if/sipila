{% if not is_htmx %}
    {% extends "admin/layout.jinja" %}
    {% block title %}Monitor Peminjaman{% endblock %}
{% else %}
    <title>Monitor Peminjaman</title>
{% endif %}

{% from 'macros.jinja' import render_notif %}

{% block content %}

{{ render_notif(error, success, info) }}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h4 class="mb-0">Monitor Peminjaman</h4>
    <div style="min-width:220px">
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
            <input type="date" id="monitorTanggal" class="form-control"
                   value="{{ tanggal.strftime('%Y-%m-%d') }}"
                   min="{{ min_date.strftime('%Y-%m-%d') }}"
                   max="{{ max_date.strftime('%Y-%m-%d') }}">
        </div>
    </div>
</div>

<div class="table-responsive">
        <table id="monitorTable" class="table table-striped table-bordered table-sm">
            <thead>
                <tr>
                    <th>No</th>
                    <th>NIS</th>
                    <th>Nama Siswa</th>
                    <th>Rombel</th>
                    <th>Kategori</th>
                    <th>Catatan Siswa</th>
                    <th>Penanggung Jawab</th>
                    <th>Konfirmasi Penggunaan</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
</div>

<div class="card mt-4">
    <div class="card-body">
        <h5 class="card-title mb-3">
            <i class="bi bi-file-earmark-spreadsheet"></i> Unduh Laporan
        </h5>
        <div class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small mb-1" for="laporanMulai">Tanggal Mulai</label>
                <input type="date" id="laporanMulai" class="form-control"
                       value="{{ min_date.strftime('%Y-%m-%d') }}"
                       min="{{ min_date.strftime('%Y-%m-%d') }}"
                       max="{{ max_date.strftime('%Y-%m-%d') }}">
            </div>
            <div class="col-auto">
                <label class="form-label small mb-1" for="laporanAkhir">Tanggal Akhir</label>
                <input type="date" id="laporanAkhir" class="form-control"
                       value="{{ tanggal.strftime('%Y-%m-%d') }}"
                       min="{{ min_date.strftime('%Y-%m-%d') }}"
                       max="{{ max_date.strftime('%Y-%m-%d') }}">
            </div>
            <div class="col-auto">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" id="laporanHanyaDigunakan">
                    <label class="form-check-label" for="laporanHanyaDigunakan">
                        Hanya yang digunakan
                    </label>
                </div>
            </div>
            <div class="col-auto">
                <button type="button" class="btn btn-success" id="btnUnduhLaporan">
                    <i class="bi bi-download"></i> Unduh Excel
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalKonfirmasi" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalKonfirmasiTitle">Konfirmasi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>
            <div class="modal-body" id="modalKonfirmasiBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn" id="modalKonfirmasiBtn">Konfirmasi</button>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="monitorToast" class="toast" role="alert" aria-live="assertive">
        <div class="toast-body" id="monitorToastMsg"></div>
    </div>
</div>

<script>
var monitorTable = null;
var csrfToken = '{{ csrf_token() }}';
var konfirmasiRequestId = null;
var konfirmasiValue = null;

var tampilkan_toast = function(msg) {
    document.getElementById('monitorToastMsg').textContent = msg;
    new bootstrap.Toast(document.getElementById('monitorToast')).show();
};

var konfirmasi_penggunaan = function(id, value) {
    konfirmasiRequestId = id;
    konfirmasiValue = value;
    var title = value === 'used' ? 'Konfirmasi Digunakan' : 'Konfirmasi Tidak Digunakan';
    var body = value === 'used'
        ? 'Apakah Anda yakin ingin mengkonfirmasi permintaan ini sebagai <strong>digunakan</strong>?'
        : 'Apakah Anda yakin ingin mengkonfirmasi permintaan ini sebagai <strong>tidak digunakan</strong>?';
    var btnClass = value === 'used' ? 'btn btn-success' : 'btn btn-danger';
    var btnText = value === 'used' ? 'Digunakan' : 'Tidak Digunakan';

    document.getElementById('modalKonfirmasiTitle').textContent = title;
    document.getElementById('modalKonfirmasiBody').innerHTML = body;
    var btn = document.getElementById('modalKonfirmasiBtn');
    btn.className = btnClass;
    btn.textContent = btnText;
    new bootstrap.Modal(document.getElementById('modalKonfirmasi')).show();
};

document.getElementById('modalKonfirmasiBtn').addEventListener('click', function() {
    if (!konfirmasiRequestId || !konfirmasiValue) return;
    var formData = new FormData();
    formData.append('csrf_token', csrfToken);

    var url;
    if (konfirmasiValue === 'cancel') {
        url = '/supervisor/monitor/batalkan_konfirmasi/' + konfirmasiRequestId;
    } else {
        formData.append('confirmation', konfirmasiValue);
        url = '/supervisor/monitor/konfirmasi/' + konfirmasiRequestId;
    }

    fetch(url, { method: 'POST', body: formData })
    .then(function(resp) { return resp.json(); })
    .then(function(data) {
        bootstrap.Modal.getInstance(document.getElementById('modalKonfirmasi')).hide();
        tampilkan_toast(data.message);
        if (data.success) muat_data();
    });
});

var batalkan_konfirmasi = function(id) {
    konfirmasiRequestId = id;
    document.getElementById('modalKonfirmasiTitle').textContent = 'Batalkan Konfirmasi';
    document.getElementById('modalKonfirmasiBody').innerHTML =
        'Apakah Anda yakin ingin <strong>membatalkan konfirmasi</strong> pada permintaan ini?';
    var btn = document.getElementById('modalKonfirmasiBtn');
    btn.className = 'btn btn-warning';
    btn.textContent = 'Batalkan Konfirmasi';
    konfirmasiValue = 'cancel';
    new bootstrap.Modal(document.getElementById('modalKonfirmasi')).show();
};

var render_konfirmasi = function(data, type, row) {
    var id = row.request_id;
    if (row.confirmation === 'used') {
        return '<span class="badge bg-success">Digunakan</span>'
            + ' <button class="btn btn-sm btn-outline-secondary ms-1" onclick="batalkan_konfirmasi(' + id + ')">'
            + '<i class="bi bi-arrow-counterclockwise"></i></button>';
    } else if (row.confirmation === 'not_used') {
        return '<span class="badge bg-danger">Tidak Digunakan</span>'
            + ' <button class="btn btn-sm btn-outline-secondary ms-1" onclick="batalkan_konfirmasi(' + id + ')">'
            + '<i class="bi bi-arrow-counterclockwise"></i></button>';
    }
    return '<span class="badge bg-warning text-dark">Belum</span>'
        + ' <button class="btn btn-sm btn-outline-success ms-1" onclick="konfirmasi_penggunaan(' + id + ', \'used\')" title="Digunakan">'
        + '<i class="bi bi-check-lg"></i></button>'
        + ' <button class="btn btn-sm btn-outline-danger ms-1" onclick="konfirmasi_penggunaan(' + id + ', \'not_used\')" title="Tidak Digunakan">'
        + '<i class="bi bi-x-lg"></i></button>';
};

var muat_data = function() {
    var tanggal = document.getElementById('monitorTanggal').value;
    if (monitorTable) {
        monitorTable.ajax.url('{{ url_for("supervisor.monitor_data") }}?tanggal=' + tanggal).load();
        return;
    }
    monitorTable = $('#monitorTable').DataTable({
        ajax: {
            url: '{{ url_for("supervisor.monitor_data") }}?tanggal=' + tanggal,
            dataSrc: 'data'
        },
        columns: [
            { data: 'no' },
            { data: 'student_nis' },
            { data: 'student_name' },
            { data: 'class_group' },
            { data: 'category' },
            { data: 'student_note' },
            { data: 'reviewer' },
            { data: null, render: render_konfirmasi, orderable: false }
        ],
        order: [[0, 'asc']],
        language: {
            search: 'Cari:',
            lengthMenu: 'Tampilkan _MENU_ data',
            info: 'Menampilkan _START_ - _END_ dari _TOTAL_ data',
            infoEmpty: 'Belum ada data',
            emptyTable: 'Tidak ada permintaan yang diterima pada tanggal ini',
            zeroRecords: 'Tidak ditemukan data yang cocok',
            paginate: { previous: 'Sebelumnya', next: 'Selanjutnya' }
        }
    });
};
var unduh_laporan = function() {
    var mulai = document.getElementById('laporanMulai').value;
    var akhir = document.getElementById('laporanAkhir').value;
    var hanyaDigunakan = document.getElementById('laporanHanyaDigunakan').checked ? '1' : '0';
    var params = new URLSearchParams({
        tanggal_mulai: mulai,
        tanggal_akhir: akhir,
        hanya_digunakan: hanyaDigunakan
    });
    window.location.href = '{{ url_for("supervisor.monitor_export") }}?' + params.toString();
};

(function() {
    if ($.fn.DataTable.isDataTable('#monitorTable')) {
        $('#monitorTable').DataTable().destroy();
        $('#monitorTable').empty();
    }
    muat_data();
    document.getElementById('monitorTanggal').addEventListener('change', muat_data);
    document.getElementById('btnUnduhLaporan').addEventListener('click', unduh_laporan);
})();
</script>

{% endblock %}
